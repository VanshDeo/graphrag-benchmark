CREATE OR REPLACE QUERY graphrag_stream_all_ids(STRING v_type) {
  ListAccum<STRING> @@ids;
  Verts = {v_type};
  Verts = SELECT v FROM Verts:v
          ACCUM @@ids += v.id;
  PRINT @@ids;
}
